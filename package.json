{
  "name": "planning-poker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "vercel-build": "pnpm run build:client",
    "start": "NODE_ENV=production node dist/server/index.js",
    "test": "vitest run --root .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.api.json",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vercel/blob": "2.6.1",
    "express": "5.2.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3",
    "vite": "8.0.12"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  }
}
